# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
BOT_LANGUAGE=en
SUPPORTED_FORMATS=epub,mobi,azw3
OUTPUT_FORMAT=mobi

# Kindle Configuration
# Host mount point where the Kindle is mounted (on your Linux/macOS host)
KINDLE_MOUNT_POINT=/mnt/kindle
# Container path where the host mount is exposed
CONTAINER_KINDLE_MOUNT_POINT=/kindle
# Propagation mode for bind mount updates. Keep rshared on Linux so late host mounts become visible.
KINDLE_BIND_PROPAGATION=rshared
# For removable VFAT/exFAT mounts that cannot be relabeled, disable SELinux labeling for this service.
CONTAINER_SECURITY_OPT=label=disable
KINDLE_DOCUMENTS_FOLDER=documents

# Logging
LOG_LEVEL=INFO
